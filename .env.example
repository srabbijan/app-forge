# Base path for GitHub Pages deployment (auto-set in CI)
# For local dev, leave as "/" or omit entirely
VITE_BASE_PATH=/

# API base URL — set this in GitHub repo Settings → Variables → Actions
VITE_API_BASE_URL=https://api.example.com

# GitHub Actions workflow trigger
VITE_GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
VITE_GH_REPO_OWNER=HishaBee-Technologies-Limited
VITE_GH_REPO_NAME=HishabeeEcomAppKmp
VITE_GH_BRANCH=master
